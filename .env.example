# ══════════════════════════════════════════════════════════════════════════
#  CentineLab — Variables de entorno
#  Copia este archivo como .env y rellena los valores reales.
#  NUNCA subas el archivo .env a Git (está en .gitignore).
# ══════════════════════════════════════════════════════════════════════════

# ── General ───────────────────────────────────────────────────────────────
APP_NAME=CentineLab
APP_VERSION=0.2.0
DEBUG=false

# ── Base de datos ─────────────────────────────────────────────────────────
# Desarrollo (SQLite — no requiere servidor)
DATABASE_URL=sqlite:///./centinelab.db

# Producción (PostgreSQL — descomentar y rellenar)
# DATABASE_URL=postgresql+psycopg2://usuario:contraseña@localhost:5432/centinelab

# ── SMTP (notificaciones por email) ───────────────────────────────────────
# Ejemplo con Gmail:
#   SMTP_HOST=smtp.gmail.com
#   SMTP_PORT=587
#   SMTP_USER=tu@gmail.com
#   SMTP_PASSWORD=tu_app_password   # Contraseña de aplicación, no la de la cuenta
SMTP_HOST=
SMTP_PORT=587
SMTP_TLS=true
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=centinelab@hospital.local

# ── Seguridad ─────────────────────────────────────────────────────────────
# Generar una clave segura: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=cambia-esta-clave-en-produccion
